                  user-select: text !important;
              }


              lighter {
                  font-family: inherit !important;
                  font-size: inherit !important;
                  font-weight: inherit !important;
                  cursor: pointer !important;
              }

              lighter {
                background-image: initial !important;
              }


              l-core.L-underline {
                border-bottom: 2px solid rgba(64, 158, 255, 1) !important;
                animation: L-coreBorderAnimation 1s;
                background: rgba(64, 158, 255, 0.2) !important;
                cursor: pointer !important;
              }

              l-core.L-auto-highlight {
                cursor: pointer;
                text-decoration: underline;
                text-decoration-style: dotted;
                text-decoration-color: #EAFFB6;
                background: #EAFFB6;
              }
              
          
              
              l-core.L-auto-highlight.active {
                cursor: pointer;
                text-decoration: underline;
                text-decoration-style: dotted;
                text-decoration-color: #ddf997;
                background: #ddf997; 
              }

              l-core.L-auto-highlight.L-hidden {
                cursor: auto;
                text-decoration: auto;
                text-decoration-style: revert;
                text-decoration-color: inherit;
                background: inherit;
              } 


              l-core.L-summary-content {
                background: #FFCA90 !important;
                cursor: pointer !important;
              }

              l-core.L-underline.L-bgHover {
                background: #ECEFED !important;
                transition: background 0.2s !important;
              }

              @keyframes L-coreBorderAnimation {
                0% {
                  border-bottom-color: rgba(64, 158, 255, 0.5)
                }
                100% {
                  border-bottom-color: rgba(64, 158, 255, 1)
                }
              }

              .ab-iam-root {
                  z-index: 99999999999999999999 !important;
              }

              .OrderDetails-items {
                  display: none;
              }

              .OrderDetails-footer .OrderDetailsFooter-subtotal {
                  display: none;
              }

              .OrderDetails-footer .OrderDetailsFooter-subtotalItems {
                  display: none;
              }

              .OrderDetails-footer .OrderDetails-total {
                  display: none;
              }

              .PSPDFKit-Popover-Text-Markup-Toolbar {
                  display: none;
              }

              .liner-mini-button {
                  display: none;
                  position: absolute !important;
                  width: auto;
                  height: 30px !important;
                  z-index: 999999999999 !important;
              }

              .liner-mini-button .liner-mb {
                  display: flex;
                  cursor: pointer !important;
                  max-width: initial !important;
                  width: 30px !important;
                  height: 30px !important;
                  position: absolute !important;
                  left: 0 !important;
                  top: 0 !important;
                  opacity: 1 !important;
                  border: none !important;
                  -webkit-box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2) !important;
                  -moz-box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2) !important;
                  box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2) !important;
                  background-color: #ffffff !important;
                  border-radius: 40px !important;
                  background-size: 20px !important;
                  background-position: center !important;
                  background-repeat: no-repeat !important;
                  background-image: url("data:image/svg+xml;base64,") !important;

              }

              .liner-mini-button .liner-mb:not(.liner-mb-disabled)::after {
                position: absolute !important;
                bottom: 5px !important;
                left: 5px !important;
                content: '' !important;
                background: #ffff83;
                width: 20px !important; 
                height: 3px !important;
                border-radius: 2px !important;
              }

              .liner-mini-button .liner-mb.liner-mb-disabled {
                background-size: 30px !important;
                background-image: url("data:image/svg+xml;base64,") !important;
              }

              .liner-page-tooltip-body-point {
                  position: absolute !important;
                  left: 2px !important;
                  top: 9px !important;
                  width: 8px !important;
                  height: 8px !important;
                  z-index: 2 !important;
                  background-color: #52565d !important;
                  border-top: 1px solid #969aa2 !important;
                  border-left: 1px solid #969aa2 !important;
                  border-top-left-radius: 4px !important;
                  transform: rotate(317deg) skew(16deg, 12deg) !important;
              }

              .liner-page-text-only-tooltip {
                  position: relative !important;
              }

              .liner-page-tooltip-body {
                  display: table !important;
                  margin-left: 6px !important;
                  padding: 5px 11px !important;
                  background-color: #52565d !important;
                  border: 1px solid #969aa2 !important;
                  border-radius: 8px !important;
                  box-shadow: 0 4px 8px 0 rgba(39, 43, 49, 0.3) !important;
                  font-family: system-ui !important;
                  font-stretch: normal !important;
                  font-style: normal !important;
                  font-weight: 400 !important;
                  line-height: 1.3em !important;
                  letter-spacing: -.35px !important;
                  font-size: 12px !important;
                  color: #fff !important;
                  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5) !important;
              }

              .liner-page-tooltip-body span {
                  display: inline-block !important;
              }

              .liner-mini-tooltip {
                  display: none;
                  position: absolute !important;
                  z-index: 1003 !important;
              }

              .liner-mini-tooltip.liner-enabled {
                  width: 186px !important;
                  height: 30px !important;
                  padding: 6px 2px 6px 35px !important;
                  box-sizing: border-box !important;
                  border-radius: 30px !important;
                  box-shadow: 0 1px 4px 0 rgba(0, 0, 0, 0.2) !important;
                  background-color: #fff !important;
              }

              .liner-mini-color-circle {
                  display: flex !important;
                  align-items: center !important;
                  justify-content: center !important;
                  position: relative !important;
                  width: 18px !important;
                  height: 18px !important;
                  margin: 0 3px !important;
                  float: left !important;
                  border-radius: 50% !important;
                  cursor: pointer !important;
              }

              .liner-mini-color-circle.liner-color-lock {
                user-select: none !important;
              }

              .liner-color-label, .liner-youtube-color-label {
                  display: none;
                  position: absolute;
                  max-width: 80px;
                  text-overflow: ellipsis;
                  overflow: hidden;
                  white-space: nowrap;
                  height: 17px;
                  top: -24px;
                  padding: 2px 3px 0px 3px;
                  color: white;
                  background-color: #52565D;
                  border-radius: 2px;
                  font-family: system-ui !important;
                  font-weight: 400;
                  font-size: 11px;
                  line-height: 13px;
              }

              .liner-mini-color-circle:hover .liner-color-label {
                display: block;
              }

              .liner-color-label.LinerHover, .liner-youtube-color-label.LinerHover {
                display: block;
              }

              .liner-tooltip-icon:hover, .liner-youtube-tooltip-icon:hover {
                  background-color: #f2f3f7 !important;
                  border-radius: 30px !important;
                  transition: background-color 0.3s !important;
              }

              .liner-tooltip-color-picker-icon-part, .liner-youtube-tooltip-color-picker-icon-part {
                  position: absolute !important;
                  display: inline-block !important;
                  width: 18px !important;
                  height: 18px !important;
                  border-radius: 100px !important;
              }

              .liner-tooltip-menu .liner-tooltip-color, .liner-youtube-tooltip-menu .liner-youtube-tooltip-color {
                  position: absolute !important;
                  top: 3px !important;
                  left: 10px !important;
                  display: inline-block !important;
                  width: 28px !important;
                  height: 28px !important;
              }

              .liner-youtube-tooltip-menu .liner-youtube-tooltip-color {
                cursor: pointer !important;
              }

              .liner-tooltip-menu.liner-desktop .liner-tooltip-color, .liner-youtube-tooltip-menu .liner-youtube-tooltip-color {
                position: unset !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
              }

              .liner-tooltip-menu .liner-tooltip-comment, .liner-youtube-tooltip-menu .liner-youtube-tooltip-comment {
